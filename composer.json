{
    "name": "iliaal/phonetic",
    "type": "php-ext",
    "description": "Native phonetic matching for PHP: Double Metaphone, Beider-Morse Phonetic Matching, and Daitch-Mokotoff Soundex.",
    "keywords": ["phonetic", "double-metaphone", "metaphone", "beider-morse", "bmpm", "daitch-mokotoff", "soundex", "fuzzy-matching", "php-extension", "pie"],
    "license": ["BSD-3-Clause", "Apache-2.0"],
    "homepage": "https://github.com/iliaal/phonetic",
    "authors": [
        {
            "name": "Ilia Alshanetsky",
            "email": "ilia@ilia.ws"
        }
    ],
    "require": {
        "php": ">=8.1"
    },
    "php-ext": {
        "extension-name": "phonetic",
        "configure-options": [
            {
                "name": "enable-phonetic",
                "description": "Enable phonetic support",
                "needs-value": false
            },
            {
                "name": "enable-phonetic-dev",
                "description": "Enable -Werror and strict checks for wrapper code (development builds)",
                "needs-value": false
            }
        ],
        "support-zts": true,
        "support-nts": true,
        "download-url-method": ["pre-packaged-binary", "composer-default"]
    }
}
